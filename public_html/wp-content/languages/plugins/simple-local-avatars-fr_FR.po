msgid "10up"
msgstr "10up"

#: includes/class-simple-local-avatars.php:1077
msgid "Only images can be uploaded as an avatar"
msgstr "Uniquement des images peuvent être téléversées en tant qu‘avatar"

#. translators: %s: Formatted size.
#: includes/class-simple-local-avatars.php:1085
msgid "Max allowed avatar size is %s"
msgstr "La taille maximale autorisée pour l‘avatar est de %s"

#: includes/class-simple-local-avatars.php:841
msgid "Choose default avatar"
msgstr "Choisir l‘avatar par défaut"

#: includes/class-simple-local-avatars.php:235
msgid "Settings"
msgstr "Réglages"

#: includes/class-simple-local-avatars.php:703
#: includes/class-simple-local-avatars.php:707
msgid "Mode"
msgstr "Mode"

#: includes/class-simple-local-avatars.php:708
msgid "Default to the settings below when creating a new site"
msgstr "Définir les réglages ci-dessous par défaut lors de la création d‘un nouveau site."

#: includes/class-simple-local-avatars.php:709
msgid "Enforce the settings below across all sites"
msgstr "Appliquer les réglages ci-dessous à tous les sites"

#: includes/class-simple-local-avatars.php:893
msgid "Clear cache"
msgstr "Vider le cache"

#: includes/class-simple-local-avatars.php:844
msgid "Migration in progress."
msgstr "Migration en cours."

#: includes/class-simple-local-avatars.php:624
#: includes/class-simple-local-avatars.php:737
msgid "Only allow users with file upload capabilities to upload local avatars (Authors and above)"
msgstr "N’autorisez uniquement les utilisateurs et utilisatrices ayant les permision de téléversements de fichier à téléverser les avatars local (Auteurs/Autrice et supérieur)"

#: includes/class-simple-local-avatars.php:612
#: includes/class-simple-local-avatars.php:722
msgid "Only allow local avatars (still uses Gravatar for default avatars)"
msgstr "Autoriser uniquement les avatars locaux (utilise toujours Gravatar pour les avatars par défaut)"

#: includes/class-simple-local-avatars.php:930
msgid "Avatar"
msgstr "Avatar"

#: includes/class-simple-local-avatars.php:934
msgid "Upload Avatar"
msgstr "Envoyer un Avatar"

#: includes/class-simple-local-avatars.php:985
msgid "No local avatar is set. Set up your avatar at Gravatar.com."
msgstr "Aucun avatar local. Configurez votre avatar sur Gravatar.com."

#: includes/class-simple-local-avatars.php:987
msgid "You do not have media management permissions. To change your local avatar, contact the blog administrator."
msgstr "Vous n'avez pas les autorisations nécessaire pour gérer les médias. Pour changer votre avatar local, contacter l'administrateur du blog."

